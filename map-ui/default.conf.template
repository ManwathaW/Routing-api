server {
    listen ${PORT};
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # Long cache for static index (single-file app — bust by redeploy).
    location = /index.html {
        add_header Cache-Control "no-cache";
    }
}
